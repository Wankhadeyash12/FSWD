# MongoDB - Replace with your MongoDB Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/shopsphere

# JWT Secret
JWT_SECRET=shopsphere_super_secret_jwt_key_2024

# Razorpay - Replace with your Razorpay test keys
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Cloudinary - Replace with your Cloudinary credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Server
PORT=5000
